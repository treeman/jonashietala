# New and complete bootstrap

```
terraform apply
just init_cluster_config

# Nodes will not be ready
# Gateway CRDs need to exist before we install cilium
kubectl apply -f https://github.com/kubernetes-sigs/gateway-api/releases/download/v1.2.1/standard-install.yaml
helm install cilium cilium/cilium \
  --namespace kube-system \
  --version 1.19.2 \
  --set kubeProxyReplacement=true \
  --set k8sServiceHost=10.1.4.100 \
  --set k8sServicePort=6443 \
  --set l2announcements.enabled=true \
  --set externalIPs.enabled=true \
  --set gatewayAPI.enabled=true \
  --set ipam.mode=kubernetes \
  --set operator.replicas=1 \
  --set securityContext.privileged=true

# Need to wait until done
kubectl rollout status daemonset/cilium -n kube-system
# Then we can do
kubectl apply -f gitops/bootstrap/cilium_config.yaml
# Nodes will now become healthy
talosctl -n 10.1.4.10 health

helm repo add argo https://argoproj.github.io/argo-helm
helm repo update
helm install argocd argo/argo-cd -n argocd --create-namespace --version 9.4.16 \
  --set server.service.type=LoadBalancer \
  --set server.service.annotations."io\.cilium/lb-ipam-ips"=10.1.4.102
# See ip
kubectl get svc argocd-server -n argocd
argocd admin initial-password -n argocd
# Username `admin`
argocd login 10.1.4.102 --insecure
argocd account update-password
argocd repo add https://git.hietala.xyz/tree/home-ops.git --username admin --password <token>

kubectl create namespace renovate
kubectl create secret generic renovate-token --namespace renovate --from-literal=RENOVATE_TOKEN=<token>

kubectl create namespace cert-manager
kubectl create secret generic namecheap-credentials \
  --namespace cert-manager \
  --from-literal=apiKey=<your-api-key> \
  --from-literal=apiUser=<your-namecheap-username>

kubectl apply -f gitops/root.yaml
```

# Local path and postgres

Setup local path

```
kubectl get storageclass
NAME                   PROVISIONER                            RECLAIMPOLICY   VOLUMEBINDINGMODE      ALLOWVOLUMEEXPANSION   AGE
local-path (default)   cluster.local/local-path-provisioner   Delete          WaitForFirstConsumer   true                   7m7s
```

```
# Get password
kubectl get secret postgres-app -n cnpg-system -o jsonpath='{.data.password}' | base64 -d
psql -h 10.1.4.103 -U app
# Or
PGPASSWORD=<password> psql -h 10.1.4.103 -U app
# Or
kubectl exec -n cnpg-system postgres-1 -- psql -U postgres
# Allow app user to create database
kubectl exec -n cnpg-system postgres-1 -- psql -U postgres -c "ALTER USER app CREATEDB;"
# Login
```

## Backups


```
CNPG
  └─► Garage (in-cluster, S3-compatible)
        └─► NFS mount → vault/postgres on Proxmox ZFS
                └─► Sanoid/Syncoid → secondary machine (future)
                └─► Restic/Rclone → Backblaze B2
```

