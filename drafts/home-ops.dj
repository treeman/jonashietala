Get Bearer token:

```
kubectl get secret -n garage garage-secrets -o jsonpath='{.data.GARAGE_ADMIN_TOKEN}' | base64 -d
```

Then check that the bucket `postgres-backups` exist:

```
kubectl port-forward -n garage svc/garage 3903:3903
curl localhost:3903/v2/GetBucketInfo?globalAlias=postgres-backups -H "Authorization: Bearer <token>"
```

WAL 30 days + daily scheduled backups gives proper restoration capabilities.

To verify:

1. `kubectl get cluster postgres -n cnpg-system -o jsonpath='{.status.conditions}' | jq .`

  ```json
  {
    "lastTransitionTime": "2026-03-27T13:20:11Z",
    "message": "Continuous archiving is working",
    "reason": "ContinuousArchivingSuccess",
    "status": "True",
    "type": "ContinuousArchiving"
  }
  ```

2. Trigger manual backup

  Install tool:

  ```
  curl -sSfL \
    https://github.com/cloudnative-pg/cloudnative-pg/raw/main/hack/install-cnpg-plugin.sh | \
    sudo sh -s -- -b /usr/local/bin
  ```

  ```
  $ kubectl cnpg backup postgres -n cnpg-system
  backup/postgres-20260329103904 created
  ```

3. Verify manual backup

  ```
  # See that backup is running:
  kubectl get backup -n cnpg-system -w
  # View logs
  kubectl logs -n cnpg-system postgres-1 -c postgres -f | grep -i backup
  ```

4. Verify bucket objects/bytes are non-zero

   ```
   curl localhost:3903/v2/GetBucketInfo?globalAlias=postgres-backups -H "Authorization: Bearer <token>"
   ```

Create a new postgres cluster from backup (named `postgres-tmp`).

```
apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: postgres-tmp
  namespace: cnpg-system
  annotations:
    argocd.argoproj.io/sync-options: SkipDryRunOnMissingResource=true
spec:
  instances: 1
  imageName: ghcr.io/inherent-design/cloudnative-pg-timescaledb:18
  storage:
    storageClass: local-path
    size: 200Gi
  postgresql:
    shared_preload_libraries:
      - timescaledb
  env:
    - name: AWS_DEFAULT_REGION
      value: garage
  bootstrap:
    recovery:
      source: primary
  externalClusters:
    - name: primary
      barmanObjectStore:
        serverName: postgres
        endpointURL: http://garage.garage.svc.cluster.local:3900
        destinationPath: s3://postgres-backups/
        s3Credentials:
          accessKeyId:
            name: postgres-backup-s3
            key: ACCESS_KEY_ID
          secretAccessKey:
            name: postgres-backup-s3
            key: ACCESS_SECRET_KEY
        wal:
          compression: gzip
```

Same as the main cluster except it uses `externalClusters` as the source.

Connect:

```
# View pod name
kubectl get pods -n cnpg-system
# Connect via the pod
kubectl exec -it -n cnpg-system postgres-tmp-1 -- psql -U postgres
```

[Spegel]: https://spegel.dev/

# Spegel setup

# Authentik SSO + idp

```
set -x SECRET_KEY (openssl rand 60 | base64 -w 0
set -x PG_PASSWORD (openssl rand 60 | base64 -w 0)

 kubectl create secret generic authentik \
  --namespace authentik \
  --from-literal=secret-key="$SECRET_KEY" \
  --from-literal=postgresql-password="$PG_PASSWORD" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name=sealed-secrets-controller \
    --controller-namespace=sealed-secrets > gitops/apps/authentik/authentik-secret.yaml

kubectl create secret generic authentik-pg \
  --namespace cnpg-system \
  --from-literal=username="authentik" \
  --from-literal=password="$PG_PASSWORD" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name=sealed-secrets-controller \
    --controller-namespace=sealed-secrets > gitops/apps/postgres/authentik-pg-secret.yaml
```

For miniflux:

```
kubectl create secret generic miniflux-authentik \
                                    --namespace miniflux \
                                    --from-literal=client-id="<id>" \
                                    --from-literal=client-secret="<secret>" \
                                    --dry-run=client -o yaml | \
                                    kubeseal --format yaml \
                                      --controller-name=sealed-secrets-controller \
                                      --controller-namespace=sealed-secrets \
                                    > gitops/apps/miniflux/miniflux-authentik-secret.yaml
```

For argocd:

```
kubectl create secret generic argocd-authentik-secret \
  --namespace argocd \
  --from-literal=dex.authentik.clientSecret="<secret>" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name=sealed-secrets-controller \
    --controller-namespace=sealed-secrets \
  > gitops/bootstrap/argocd-authentik-secret.yaml
```

# External DNS OPNSense

Need an api key + secret from OPNsense.

```
kubectl create secret generic external-dns \
  --namespace external-dns \
  --from-literal=api-key="YOUR_API_KEY" \
  --from-literal=api-secret="YOUR_API_SECRET" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name=sealed-secrets-controller \
    --controller-namespace=sealed-secrets \
  > gitops/apps/external-dns/external-dns-secret.yaml
```

# Headlamp

```
kubectl create secret generic headlamp-oidc \
  --namespace headlamp \
  --from-literal=OIDC_CLIENT_ID="<id>" \
  --from-literal=OIDC_CLIENT_SECRET="<secret>" \
  --from-literal=OIDC_ISSUER_URL="https://auth.hietala.xyz/application/o/kubernetes/" \
  --from-literal=OIDC_SCOPES="openid profile email" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name=sealed-secrets-controller \
    --controller-namespace=sealed-secrets \
  > gitops/apps/headlamp/headlamp-secret.yaml
  ```
